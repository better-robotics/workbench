#!/usr/bin/env bash
# Fast pre-commit checks. Bypassable with `git commit --no-verify` —
# CI is the binding layer; this is just fast feedback so common
# mistakes don't survive a 5-minute round-trip.
#
# Install: `make install-hooks` (sets core.hooksPath = .githooks).

set -e

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

# 1. Generated-UUIDs drift. Only fires when protocol/uuids.json is staged —
# casual commits on unrelated files don't pay for the regen.
if git diff --cached --name-only | grep -q '^protocol/uuids\.json$'; then
    python3 tools/gen-uuids.py >/dev/null
    GEN="firmware/esp32_robot_idf/main/uuids.h firmware/pi_robot/uuids.py docs/uuids.js"
    if ! git diff --quiet -- $GEN; then
        echo "pre-commit: generated UUID files are out of sync with protocol/uuids.json"
        echo "  fix: make gen-uuids && git add $GEN"
        exit 1
    fi
fi

# 2. SW version stamp. Hashes the dashboard asset surface and rewrites
# docs/sw.js's VERSION when the hash changes. Bumping VERSION is what
# makes the browser see a new service worker and surface the "Reload to
# update" banner. Folded into the user's commit so the banner fires on
# the right SHA. Only runs when docs/* (excluding firmware bins +
# sw.js itself) is staged.
if git diff --cached --name-only \
    | grep -E '^docs/' \
    | grep -vE '^docs/firmware/|^docs/sw\.js$' \
    | grep -q .; then
    HASH=$(git ls-files -s -- 'docs/*' ':!docs/firmware/*' ':!docs/sw.js' \
        | shasum -a 256 | cut -c1-8)
    CUR=$(grep -E '^const VERSION = ' docs/sw.js | sed 's/.*"\(.*\)".*/\1/')
    if [ "$HASH" != "$CUR" ]; then
        # Rewrite-and-mv form is portable; `sed -i` differs between
        # BSD (macOS) and GNU.
        sed "s|^const VERSION = .*|const VERSION = \"$HASH\";|" docs/sw.js > docs/sw.js.tmp \
            && mv docs/sw.js.tmp docs/sw.js
        git add docs/sw.js
        echo "pre-commit: stamped sw.js VERSION = $HASH"
    fi
fi

# 3. Pure-function smoke tests. Sub-second. Catches regressions in
# format.js (and future pure helpers) before they reach CI.
make -s smoke
