menu "Sprocket Robotics"

choice BR_BOARD
    prompt "Target board"
    default BR_BOARD_AITHINKER_CAM if IDF_TARGET_ESP32
    default BR_BOARD_S3_CAM        if IDF_TARGET_ESP32S3
    default BR_BOARD_C3_SUPERMINI  if IDF_TARGET_ESP32C3
    help
        Selects board-specific defaults: camera/PSRAM presence, pin map
        defaults, and the forbidden-pin set used by pin_config.c's
        validator. Choices are filtered to the active IDF target.

config BR_BOARD_AITHINKER_CAM
    bool "AI-Thinker ESP32-CAM (camera + PSRAM)"
    depends on IDF_TARGET_ESP32
    select BR_HAS_CAMERA
    select BR_HAS_PSRAM

config BR_BOARD_DEVKIT
    bool "ESP32 DevKitV1 / WROOM-32 (no camera, no PSRAM)"
    depends on IDF_TARGET_ESP32

config BR_BOARD_S3_CAM
    bool "Freenove ESP32-S3-WROOM CAM (camera + octal PSRAM + onboard WS2812)"
    depends on IDF_TARGET_ESP32S3
    select BR_HAS_CAMERA
    select BR_HAS_PSRAM
    select BR_HAS_WS2812
    select BR_HAS_PYVM

config BR_BOARD_C3_SUPERMINI
    bool "ESP32-C3 SuperMini (RISC-V, no camera, no PSRAM)"
    depends on IDF_TARGET_ESP32C3

endchoice

# Hidden caps — driven by the board choice. Source files and build deps
# gate on these, so the camera path can be dropped on no-camera boards
# without scattering CONFIG_BR_BOARD_* across every #ifdef.
config BR_HAS_CAMERA
    bool

config BR_HAS_PSRAM
    bool

# Embedded MicroPython VM (issue #47) — runs student Python scripts from the
# LittleFS drive. Needs PSRAM for the GC heap, so only PSRAM boards select it.
config BR_HAS_PYVM
    bool

# Onboard single-wire addressable RGB (WS2812/NeoPixel). Gates ws2812.c and
# the led_strip dependency; boards with a plain-GPIO LED don't select it.
config BR_HAS_WS2812
    bool

endmenu
