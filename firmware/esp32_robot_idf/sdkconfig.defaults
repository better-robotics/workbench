# Defaults applied on first build (idf.py reconfigure regenerates sdkconfig
# from these). Per-target overrides go in sdkconfig.defaults.<target>.

# WebRTC needs network + SCTP-friendly LWIP buffer sizes. Camera + NimBLE
# both want PSRAM. PSRAM mode is set per-target since classic ESP32 uses
# external SPI PSRAM and S3 uses Octal PSRAM.

# Logging
CONFIG_LOG_DEFAULT_LEVEL_INFO=y

# Bluetooth (NimBLE — matches Arduino stack)
CONFIG_BT_ENABLED=y
CONFIG_BT_NIMBLE_ENABLED=y
CONFIG_BT_CONTROLLER_ONLY=n
CONFIG_BT_BLUEDROID_ENABLED=n
# Phase 2.F.2: phone-pair via BLE-relay needs both phone and desktop
# concurrently connected to the same robot. Default is 1; bump to 4
# to give headroom (operator's phone, desktop, and a couple of guest
# clients during demos).
CONFIG_BT_NIMBLE_MAX_CONNECTIONS=4
# CCCDs are per (conn × notify-char) subscription. With 4 conns and ~10
# notify-capable chars, the default 8 is far too low — ble_gatts_count_cfg
# returns EINVAL (rc=3) and the GATT table never registers, so the
# dashboard sees "No Services matching UUID … found in Device".
CONFIG_BT_NIMBLE_MAX_CCCDS=32

# Networking — bigger LWIP buffers help SCTP throughput on data channels.
CONFIG_LWIP_TCP_SND_BUF_DEFAULT=16384
CONFIG_LWIP_TCP_WND_DEFAULT=16384
# UDP send-side: libpeer's video-frame sends spammed "sendto: ENOMEM"
# on classic ESP32 with default WiFi TX buffers. Doubling the dynamic
# tx pool gives lwIP/WiFi room to drain JPEG bursts (each ~5-15 KB)
# without throwing pbuf-alloc failures. Static rx untouched (BLE coex
# already deals with it well).
CONFIG_ESP_WIFI_DYNAMIC_TX_BUFFER_NUM=64
CONFIG_LWIP_UDP_RECVMBOX_SIZE=16

# mbedTLS — libpeer needs DTLS; default subset usually works but be explicit
CONFIG_MBEDTLS_SSL_PROTO_DTLS=y
CONFIG_MBEDTLS_HARDWARE_AES=y
CONFIG_MBEDTLS_HARDWARE_SHA=y
# Mozilla root CA bundle — wss://signal.neevs.io needs server cert verification
# without us shipping a per-host PEM in flash.
CONFIG_MBEDTLS_CERTIFICATE_BUNDLE=y
CONFIG_MBEDTLS_CERTIFICATE_BUNDLE_DEFAULT_FULL=y
# mbedTLS allocations stay in internal DRAM. Was set to SPIRAM earlier
# because ssl_setup returned SSL_ALLOC_FAILED with a fragmented heap —
# but PSRAM is 4-8× slower than DRAM and most of the chip's perceived
# 30s ICE/WebRTC handshake time was crypto running over PSRAM. With
# pair-mailbox removed and turn_creds gone, internal DRAM has room for
# the ~8 KB handshake context. If SSL_ALLOC_FAILED returns, this flips
# back on; the speedup vs the OOM-risk is worth a try.
# CONFIG_MBEDTLS_EXTERNAL_MEM_ALLOC=y

# Camera framebuffer in PSRAM
CONFIG_CAMERA_TASK_STACK_SIZE=4096

# Partition table — OTA needs two app slots + factory.
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"
